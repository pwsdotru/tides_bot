{
  "name": "pwsdotru/tides_bot",
  "description": "Telegram Bot for show information about tides",
  "type": "project",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Aleksandr Novikov",
      "email": "pwsdotru@gmail.com",
      "homepage": "https://github.com/pwsdotru"
    }
  ],
  "keywords": [
    "telegram",
    "bot",    
    "tides"
  ],
  "require": {
    "php": ">=8.0",
    "ext-curl": "*",
    "telegram-bot/api": "*"
  },
